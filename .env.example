# Sprint 1 가입 흐름 — 로컬 netlify dev 환경변수 (worktree 한정)
# 사용: cp .env.example .env && netlify dev --port 8889

# === 필수 (서명용 시크릿 — 32자 이상) ===
# JWT 토큰 서명. 실제 환경에서는 32자 이상 랜덤 문자열로 교체 필수.
JWT_SECRET=local-dev-only-jwt-secret-please-replace-32-chars-minimum

# 사이트 식별자 (LUMI_SECRET) — admin/cron endpoint 보호용. 베타 테스트 시 임의값 OK.
LUMI_SECRET=local-dev-only-lumi-secret-replace-in-production

# === 모킹 토글 (Sprint 1 베타 기본값) ===
# 사업자 인증 — 국세청 공공 API 실연동이 기본값.
# true 시: 형식+체크섬만 검증 (테스트·개발용). 실서비스에서는 false 유지.
BUSINESS_VERIFY_MOCK=false

# 사업자 진위확인 (data.go.kr 공공데이터)
# 발급: https://www.data.go.kr/data/15081808/openapi.do
# 동일 키로 날씨·축제·대기·사업자 인증 API 모두 호출 가능 (decoded key)
PUBLIC_DATA_API_KEY=

# 쿠팡 OPEN API 호출을 스킵하고 형식 검증만 수행
# 추가로 vendorId="TEST_OK"/"TEST_401"/"TEST_403"/"TEST_429"/"TEST_500" 시뮬레이션 패턴 활성
COUPANG_VERIFY_MOCK=true

# 네이버 커머스 API 호출 스킵 (TEST_OK/TEST_4xx 패턴 동일 적용)
NAVER_VERIFY_MOCK=true

# Supabase / 암호화 키 미설정 환경에서 graceful 통과 — 베타 검증용
SIGNUP_MOCK=true

# 사업자등록증 사진 업로드 — 백그라운드 검토 자동 승인 토글
# true: 업로드 즉시 'approved' (베타 운영, admin 화면 미구축 단계용)
# false (기본): 'pending' 상태로 저장, 김현 admin이 수동 승인
BUSINESS_LICENSE_AUTO_APPROVE=true

# === Sprint 1.1 OCR 자동 대조 (GPT-4o Vision) ===
# 사업자등록증 사진을 GPT-4o Vision으로 분석해 셀러 입력값과 자동 대조한다.
# true (기본/베타): 실 API 호출 없이 결정론적 모킹 응답 — 0원
# false: 실연동 (1회 ≈ ₩50). OPENAI_API_KEY 필수.
AI_OCR_MOCK=true

# OpenAI API 키 (실연동 시 필수). 평문 노출·로그 출력 절대 금지.
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 선택 (Supabase 실연동 시 필요) ===
# SUPABASE_URL=https://yourproject.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ENCRYPTION_KEY=base64-encoded-32-byte-key-or-64-hex-chars

# === Netlify Blobs (사용 안 하면 미설정 OK) ===
# NETLIFY_SITE_ID=28d60e0e-6aa4-4b45-b117-0bcc3c4268fc
# NETLIFY_TOKEN=your-personal-access-token
