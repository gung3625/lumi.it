# 루미 — 로컬 netlify dev 환경변수
# 사용: cp .env.example .env && netlify dev --port 8889

# === 필수 (서명용 시크릿 — 32자 이상) ===
# JWT 토큰 서명. 실제 환경에서는 32자 이상 랜덤 문자열로 교체 필수.
JWT_SECRET=local-dev-only-jwt-secret-please-replace-32-chars-minimum

# 사이트 식별자 (LUMI_SECRET) — admin/cron endpoint 보호용. 베타 테스트 시 임의값 OK.
LUMI_SECRET=local-dev-only-lumi-secret-replace-in-production

# === OpenAI (필수, 평문 노출·로그 출력 절대 금지) ===
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 선택 (Supabase 실연동 시 필요) ===
# SUPABASE_URL=https://yourproject.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ENCRYPTION_KEY=base64-encoded-32-byte-key-or-64-hex-chars

# === Netlify Blobs (사용 안 하면 미설정 OK) ===
# NETLIFY_SITE_ID=28d60e0e-6aa4-4b45-b117-0bcc3c4268fc
# NETLIFY_TOKEN=your-personal-access-token
